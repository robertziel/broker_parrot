# queue_workflows / broker_parrot — example environment.
# Copy to `.env` (gitignored) and fill in for your deployment. Every value below has
# a safe default in code; you only need the DSN + (for a multi-box fleet) the host
# label. Names default to the AI_LEADS_* vars for byte-compat; a host can rename them
# via queue_workflows.configure(db_url_env=…, host_label_env=…, …).

# ── required: the Postgres DSN (the durable queue lives here) ────────────────
AI_LEADS_DB_URL=postgresql://USER:PASSWORD@localhost:5432/your_db
# Pin the relational backend to Postgres. The v1.0.0 default is "sqlite"; a
# Postgres deploy MUST set this (or configure(db_backend="pg")).
QUEUE_WORKFLOWS_DB_BACKEND=pg

# ── this box's identity in the fleet ────────────────────────────────────────
# Heartbeats + worker_controls + the LLM topology key by this label. Use the box
# name (e.g. one per machine) so the panel shows <label>/<queue> per lane.
AI_LEADS_HOST_LABEL=box1
# GPU consumer priority (higher wins a contended model); 0 = default.
AI_LEADS_GPU_CONSUMER_PRIORITY=0

# ── LLM inference servers (ollama / vLLM) — deployment topology ─────────────
# ROOT URLs the backend factory dials. The DB (worker_controls) owns WHICH type a
# box runs; these hold the address. Unset ⇒ http://host.docker.internal:11434 /
# :8000. For per-box addressing use configure(llm_topology_path=…) instead — see
# docs/llm_topology.example.yml.
AI_LEADS_OLLAMA_URL=http://host.docker.internal:11434
AI_LEADS_VLLM_URL=http://host.docker.internal:8000

# ── optional: multi-tenant + alternate queue stores ─────────────────────────
# Tenant id on a SHARED broker Postgres (migration 0017); "" = single-tenant.
QUEUE_WORKFLOWS_PROJECT=
# Only when db_backend selects them (opt-in flat-queue SPI providers):
# QUEUE_WORKFLOWS_REDIS_URL=redis://localhost:6379/0
# QUEUE_WORKFLOWS_MONGO_URL=mongodb://localhost:27017   # needs a replica set
# Shared cross-app GPU pool store (pivot B):
# QUEUE_WORKFLOWS_GPU_POOL_URL=redis://localhost:6379/1

# ── optional: hw-metrics telemetry to a shared broker DB ────────────────────
# AI_LEADS_METRICS_DSN=postgresql://USER:PASSWORD@broker-host:5432/broker_db

# ── optional tuning (seconds); shown with their defaults ────────────────────
# AI_LEADS_DB_POOL_MAX=3                 # per-process connection pool cap
# AI_LEADS_LEASE_RECLAIM_INTERVAL_S=5    # lapsed-lease reclaim sweep cadence
# AI_LEADS_STALE_WORKER_AFTER_S=45       # heartbeat age → worker flagged dead
# AI_LEADS_DEAD_WORKER_SWEEP_INTERVAL_S=15
# AI_LEADS_GPU_MODEL_IDLE_TTL_S=60       # client warm-model cache idle unload
